# Ports (change to avoid conflicts with other local projects)
PORT=3000
DB_PORT=5432

# Database
# Local Docker (npm run db:up)
DATABASE_URL=postgresql://postgres:postgres@localhost:${DB_PORT}/discovered_dev
DIRECT_URL=postgresql://postgres:postgres@localhost:${DB_PORT}/discovered_dev
# Production (Supabase) — uncomment and replace the two lines above when deploying
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# JWT — generate a long random string: openssl rand -hex 32
JWT_SECRET=

# Seed — initial admin account created by `npm run db:seed`
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (email notifications)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_NOTIFY_EMAIL=
